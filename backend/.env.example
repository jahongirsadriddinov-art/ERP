# ─── Backend muhit o'zgaruvchilari (NAMUNA) ──────────────────────
# Bu faylni nusxalab `.env` yarating va haqiqiy qiymatlarni qo'ying.
# Productionда (Render/Railway) bu qiymatlar hosting panelидан beriladi.

# Server porti (Render/Railway o'zi beradi — lokalda 5000)
PORT=5000

# MongoDB ulanish satri
# Lokal:      mongodb://127.0.0.1:27017/erp_firma
# Production: MongoDB Atlas connection string (mongodb+srv://...)
MONGODB_URI=mongodb://127.0.0.1:27017/erp_firma

# Telegram bot tokeni (@BotFather dan)
TELEGRAM_BOT_TOKEN=

# JWT imzo kaliti — productionда UZUN, TASODIFIY qiymat qo'ying
JWT_SECRET=change_this_to_a_long_random_string

# Google Gemini API kaliti (smeta tahlili uchun)
GEMINI_API_KEY=
GEMINI_API_KEYS=

# Frontend URL (bot deep-link qaytish tugmasi uchun; productionда https bo'lsin)
# Lokal:      http://localhost:5173
# Production: https://erp-firma.uz
SITE_URL=http://localhost:5173

# Bot username (deep-link uchun; @ siz)
BOT_USERNAME=qurilish_erp_bot

# Backend'ning O'ZINING ochiq manzili (SITE_URL emas — u frontend manzili!).
# Bot orqali yuborilgan rasm/video/fayl/ovoz /uploads orqali shu manzildan
# xizmat qilinadi, shuning uchun Telegram uni haqiqiy URL sifatida yuklay olishi kerak.
# Lokal:      http://localhost:5000
# Production: https://qurilisherp-backend.onrender.com
BACKEND_URL=http://localhost:5000

# Dasturchi (super-admin) kirishi
DEVELOPER_PHONE=+998900960890
DEVELOPER_PASSWORD=1212

# Dasturchi Telegram chat ID — yangi obuna so'rovlari shu ID'ga yuboriladi.
# Botga /start yuboring va @userinfobot yordamida o'z chat ID'ingizni toping.
DEVELOPER_CHAT_ID=

# Gemini API kaliti (smeta parserning eski AI-yordamchi zaxira yo'li uchun,
# hozirgi oqimda ishlatilmaydi — deterministik parser AI-siz ishlaydi)
# Bir nechta kalit vergul bilan: GEMINI_API_KEYS=key1,key2
# Bitta kalit: GEMINI_API_KEY=key1

# Groq API kaliti (AI Yordamchi — console.groq.com dan bepul oling)
GROQ_API_KEY=
# Ixtiyoriy: model nomi (standart: openai/gpt-oss-120b)
GROQ_MODEL=
